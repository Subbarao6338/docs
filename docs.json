{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Technical Documentation",
  "description": "Comprehensive guides for programming languages, cloud platforms, and essential development tools.",
  "colors": {
    "primary": "#3884FF",
    "light": "#3884FF",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "appearance": {
    "default": "light"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"],
    "display": "toc"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FFFFFF"
    }
  },
  "interaction": {
    "drilldown": true
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/yourcompany/yourrepo"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/languages/python"
    }
  },
  "navigation": {
    "directory": "card",
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Languages",
        "groups": [
          {
            "group": "Web Development",
            "pages": [
              "languages/html",
              "languages/css"
            ]
          },
          {
            "group": "Programming",
            "pages": [
              "languages/python"
            ]
          },
          {
            "group": "Database",
            "pages": [
              "languages/sql"
            ]
          }
        ]
      },
      {
        "tab": "Cloud",
        "groups": [
          {
            "group": "Overview",
            "pages": ["cloud/comparison"]
          },
          {
            "group": "Platforms",
            "pages": [
              "cloud/aws",
              "cloud/azure",
              "cloud/gcp"
            ]
          }
        ]
      },
      {
        "tab": "Tools",
        "groups": [
          {
            "group": "Core Tools",
            "pages": [
              "tools/git",
              "tools/docker"
            ]
          },
          {
            "group": "AI & Automation",
            "pages": [
              "tools/ai-prompts",
              "tools/agent-skills"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "footer": {
    "socials": {
      "x": "https://x.com/yourcompany",
      "linkedin": "https://linkedin.com/company/yourcompany"
    }
  }
}
