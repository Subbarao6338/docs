{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Knowledge Hub",
  "description": "Comprehensive guides for programming languages, cloud platforms, and essential development tools.",
  "colors": {
    "primary": "#3884FF",
    "light": "#3884FF",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "appearance": {
    "default": "light"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    },
    "latex": true
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"],
    "display": "toc"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FFFFFF"
    }
  },
  "interaction": {
    "drilldown": true
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/yourcompany/yourrepo"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/"
    }
  },
  "navigation": {
    "directory": "card",
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Overview",
            "pages": ["index"]
          }
        ]
      },
      {
        "tab": "Languages",
        "groups": [
          {
            "group": "Web Development",
            "pages": [
              "languages/html",
              "languages/css",
              "languages/javascript",
              "languages/typescript"
            ]
          },
          {
            "group": "Programming",
            "pages": [
              "languages/python",
              "languages/django"
            ]
          },
          {
            "group": "Data & Analysis",
            "pages": [
              "languages/sql",
              "languages/data-science",
              "languages/notebooks",
              "languages/latex-yaml"
            ]
          }
        ]
      },
      {
        "tab": "Cloud & Infrastructure",
        "groups": [
          {
            "group": "Platforms",
            "pages": [
              "cloud/comparison",
              "cloud/aws",
              "cloud/azure",
              "cloud/gcp"
            ]
          },
          {
            "group": "Infrastructure & DevOps",
            "pages": [
              "cloud/cli",
              "tools/terraform",
              "tools/docker",
              "tools/github-actions",
              "tools/devops"
            ]
          }
        ]
      },
      {
        "tab": "Tools & AI",
        "groups": [
          {
            "group": "AI & Automation",
            "pages": [
              "tools/ai-prompts",
              "tools/agent-skills",
              "tools/ai-frameworks",
              "tools/mcp"
            ]
          },
          {
            "group": "Development",
            "pages": [
              "tools/git",
              "tools/terminal",
              "tools/markup"
            ]
          },
          {
            "group": "Enterprise",
            "pages": [
              "tools/databricks",
              "tools/adk"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Data Formats",
            "pages": [
              "languages/web-formats",
              "languages/data-formats"
            ]
          },
          {
            "group": "Utilities",
            "pages": [
              "tools/converters"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "appearance/themes"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "footer": {}
}
